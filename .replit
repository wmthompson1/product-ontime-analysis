modules = ["python-3.11", "nodejs-20", "python3", "postgresql-16", "rust-stable"]

[nix]
channel = "stable-24_05"
packages = ["arangodb", "cairo", "duckdb", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libxcrypt", "libyaml", "nano", "pkg-config", "qhull", "sqlite", "tcl", "tk", "vim", "xcodebuild", "xsimd", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/mockup-sandbox"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 23636
router = "path"

[workflows.workflow.tasks.env]
PORT = "23636"
BASE_PATH = "/__mockup/"

[[workflows.workflow]]
name = "HF Space Inventory SQL"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd hf-space-inventory-sqlgen && python app.py"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "HF Space Inventory SQL"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask App"

[[workflows.workflow]]
name = "Flask App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
run = ["sh", "-c", "python3 helloWorld.py"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 4321
externalPort = 3001

[[ports]]
localPort = 4322
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[agent]
expertMode = true

[userenv]

[userenv.shared]
ARANGO_DB = "manufacturing_graph"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
