modules = ["python-3.11", "nodejs-20", "python3", "postgresql-16", "rust-stable"]

[nix]
channel = "stable-24_05"
packages = ["arangodb", "cairo", "duckdb", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libxcrypt", "libyaml", "nano", "pkg-config", "qhull", "sqlite", "tcl", "tk", "vim", "xcodebuild", "xsimd", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Run my03regex"
author = 43354225
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 02palette.py"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Astro Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "HF Space Inventory SQL"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-resolution-messages"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-legacy-perspective"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-perspective-deprecation"

[[workflows.workflow]]
name = "Flask App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[[workflows.workflow]]
name = "Astro Dev Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd astro-sample && npm run dev"
waitForPort = 4321

[[workflows.workflow]]
name = "New Astro Server"
author = 43354225
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd hello-astro && npm run dev"

[[workflows.workflow]]
name = "Hello Astro Dev"
author = 43354225
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd hello-astro && npm run dev -- --host 0.0.0.0 --port 3000"

[[workflows.workflow]]
name = "HF Space Inventory SQL"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd hf-space-inventory-sqlgen && python app.py"
waitForPort = 8080

[[workflows.workflow]]
name = "test-resolution-messages"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python hf-space-inventory-sqlgen/tests/test_resolution_messages.py"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check-legacy-perspective"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python hf-space-inventory-sqlgen/scripts/check_legacy_perspective_refs.py"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-perspective-deprecation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python hf-space-inventory-sqlgen/tests/test_perspective_deprecation.py"

[workflows.workflow.metadata]
isValidation = true

[deployment]
run = ["sh", "-c", "python3 helloWorld.py"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 4321
externalPort = 3001

[[ports]]
localPort = 4322
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 23636
externalPort = 3003

[agent]
expertMode = true

[userenv]

[userenv.shared]
ARANGO_DB = "manufacturing_graph"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
