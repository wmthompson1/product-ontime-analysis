PREFIX : <http://example.org/manufacturing/jobcost#>

# Smoke: gl_job_cost_detail over SPARQL — per-job cost-element subledger lines.
# Compared against SELECT COUNT(*), SUM(amount) FROM gl_job_cost_detail.
SELECT (COUNT(?l) AS ?lines) (SUM(?amt) AS ?totalAmount)
WHERE {
  ?l a :JobCostLine ;
     :costAmount ?amt .
}
