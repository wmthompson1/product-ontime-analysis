PREFIX : <http://example.org/manufacturing/jobcost#>

# Smoke: gl_raw_materials_inventory over SPARQL — raw-materials credit lines.
# Compared against SELECT COUNT(*), SUM(amount) FROM gl_raw_materials_inventory.
SELECT (COUNT(?l) AS ?lines) (SUM(?amt) AS ?totalAmount)
WHERE {
  ?l a :RawMaterialsLine ;
     :rmAmount ?amt .
}
