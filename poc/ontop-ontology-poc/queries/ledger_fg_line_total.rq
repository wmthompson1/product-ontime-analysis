PREFIX : <http://example.org/manufacturing/jobcost#>

# Smoke: gl_finished_goods_inventory over SPARQL — finished-goods debit lines.
# Compared against SELECT COUNT(*), SUM(amount) FROM gl_finished_goods_inventory.
SELECT (COUNT(?l) AS ?lines) (SUM(?amt) AS ?totalAmount)
WHERE {
  ?l a :FinishedGoodsLine ;
     :fgAmount ?amt .
}
