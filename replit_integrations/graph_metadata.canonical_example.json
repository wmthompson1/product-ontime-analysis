  "milestone_name": "database_bound_unambiguous_slots",
  "synced_at": "2026-06-05T18:15:00Z",
  "description": "Hand-verified canonical example of the FIXED 6-slot composite-key graph shape. Every _key is exactly 6 slots; nodes pad slots 5-6 with 'none', edges fill them with predicate + unique_id. Defines, by example, the exact _key / _id / _from / _to / field conventions every generated record must conform to. Structural layer is active; the semantic edge is format-locked but DEFERRED to v2.",
  "key_scheme": {
    "template": "table : column|entity : family : perspective : predicate|none : unique_id|none",
    "slots": 6,
    "fixed_width": true,
    "delimiter": ":",
    "forbidden_in_component": [":", "/", ""],
    "node_collection": "manufacturing_graph_node",
    "edge_collection": "manufacturing_graph_edge",
    "reserved_tokens": {
      "entity": "slot 2 (index 1): placeholder marking a TABLE node (a table has no column)",
      "none": "slots 5-6 (index 4-5): placeholder marking a NODE (no predicate / no unique_id)",
      "system": "slot 4 (index 3): perspective reserved for the structural layer"
    },
    "name_constraints": "A real column may never be named 'entity' or 'none'; a real table may never be named 'none'; a business perspective may never be 'system'. The exporter hard-fails if any source name collides with a reserved token.",
    "parse_by": "fixed slot positions: it is a NODE iff slot[4]=='none' and slot[5]=='none' (table node if slot[1]=='entity', else column node); otherwise it is an EDGE whose family is slot[2].",
    "rules": [
      {
        "kind": "table_node",
        "slots": 6,
        "marker": "slot[1]=='entity' and slot[4:6]==['none','none']",
        "form": "table:entity:family:perspective:none:none",
        "example": "PAYABLE:entity:structural:system:none:none",
        "status": "active"
      },
      {
        "kind": "column_node",
        "slots": 6,
        "marker": "slot[1]!='entity' and slot[4:6]==['none','none']",
        "form": "table:column:family:perspective:none:none",
        "example": "PAYABLE:INVOICE_ID:structural:system:none:none",
        "status": "active"
      },
      {
        "kind": "structural_edge",
        "slots": 6,
        "marker": "slot[2]=='structural' and slot[4]!='none'",
        "form": "table:column:structural:system:predicate:unique_id",
        "example": "PAYABLE:INVOICE_ID:structural:system:has_column:PAY_INV_CONTAINMENT",
        "status": "active"
      },
      {
        "kind": "semantic_edge",
        "slots": 6,
        "marker": "slot[2]=='semantic' and slot[4]!='none'",
        "form": "table:column:semantic:perspective:predicate:unique_id",
        "example": "PAYABLE_LINE:RECEIVER_ID:semantic:Payables:elevates:PAY_ELE_RCVR_JOIN_001",
        "status": "deferred"
      }
    ]
  },
